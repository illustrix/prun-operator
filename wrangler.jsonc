{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "prun-operator",
  "compatibility_date": "2025-09-27",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "dist"
  },
  "compatibility_flags": ["nodejs_compat"],
  "env": {
    "staging": {
      "routes": [
        { "pattern": "prop-testing.auroras.xyz", "custom_domain": true }
      ]
    },
    "production": {
      "routes": [{ "pattern": "prop.auroras.xyz", "custom_domain": true }]
    }
  }
}
